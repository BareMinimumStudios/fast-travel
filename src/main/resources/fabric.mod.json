{
	"schemaVersion": 1,
	"id": "fasttravel",
	"version": "${version}",
	"name": "FastTravel",
	"description": "Fast travelling via teleporters",
	"authors": [
		"Globox_Z",
		"pokesmells"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "BML-1.0",
	"icon": "assets/fasttravel/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"net.fasttravel.FastTravelMain"
		],
		"client": [
			"net.fasttravel.FastTravelClient"
		],
		"modmenu": [
			"net.fasttravel.config.ModMenuIntegration"
		]
	},
	"mixins": [
		"fasttravel.mixins.json"
	],
	"depends": {
		"java": ">=17",
		"minecraft": ">=${minecraft_version}",
		"fabric-api": ">=${fabric_version}",
		"fabricloader": ">=${loader_version}",
		"yet_another_config_lib_v3": ">=${yacl_version}"
	},
	"suggests": {
		"another-mod": "*"
	}
}